/* app.wxss */
/* 列表容器通用样式 */
.container {
  padding: 20rpx;
  background-color: #f9f9f9;
  min-height: 100vh;
}

.header {
  padding: 20rpx 0;
  border-bottom: 1px solid #eee;
  margin-bottom: 20rpx;
}

.title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 列表项通用样式 */
.item-list {
  background-color: white;
  border-radius: 10rpx;
  overflow: hidden;
}

.item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1px solid #f5f5f5;
}

.item-content {
  flex: 1;
}

.name {
  font-size: 32rpx;
  margin-bottom: 15rpx;
  color: #333;
}

.info {
  display: flex;
  gap: 20rpx;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

/* 元素显示样式（核心） */
.elements {
  font-size: 28rpx;
  margin: 10rpx 0;
  padding: 5rpx 0;
  border-top: 1px dashed #eee;
  display: block; /* 确保可见 */
}

.elements-label {
  font-weight: 500;
  color: #666;
  margin-right: 5rpx;
}

.elements-value {
  color: #333;
}

.comment {
  font-size: 26rpx;
  color: #555;
  margin-top: 10rpx;
  line-height: 1.5;
}

/* 彻底缩小删除按钮 */
.delete-btn {
  /* 强制覆盖默认样式 */
  width: 120rpx !important; /* 固定宽度 */
  height: 60rpx !important; /* 固定高度 */
  padding: 0 !important; /* 取消内边距 */
  font-size: 22rpx !important; /* 极小字体 */
  line-height: 50rpx !important; /* 文字垂直居中（与高度一致） */
  
  background-color: #ff4d4f;
  color: white !important;
  border-radius: 4rpx;
  border: none;
  min-width: auto;
  margin-left: 10rpx; /* 与内容保持一点距离 */
}

.delete-btn::after {
  border: none; /* 彻底移除默认边框 */
}
.elements-value {
  display: inline-flex;
  gap: 5rpx; /* 元素间间距 */
}