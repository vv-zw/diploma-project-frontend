<view class="page-container">
  <view class="hero-card">
    <view class="hero-glow hero-glow-one"></view>
    <view class="hero-glow hero-glow-two"></view>
    <view class="hero-top">
      <view class="back-chip" bindtap="goBack">返回</view>
      <view class="hero-tag">ADD ENTRY</view>
    </view>
    <view class="page-title">添加影视记录</view>
    <view class="page-subtitle">填写名称、类型、评分和分类标签，快速保存到你的片单中。</view>
  </view>

  <view class="form-card">
    <view class="section-title">基础信息</view>

    <view class="field-block">
      <view class="field-label">名称</view>
      <input
        class="input-field"
        placeholder="请输入影视名称"
        bindinput="inputName"
        value="{{name}}"
      />
    </view>

    <view class="field-block">
      <view class="field-label">类型</view>
      <picker class="picker-field" value="{{typeIndex}}" range="{{types}}" bindchange="changeType">
        <view class="picker-display">{{types[typeIndex]}}</view>
      </picker>
    </view>

    <view class="field-block">
      <view class="field-label">评分</view>
      <picker class="picker-field" value="{{scoreIndex}}" range="{{scores}}" bindchange="changeScore">
        <view class="picker-display">{{score}} 星</view>
      </picker>
    </view>
  </view>

  <view class="form-card">
    <view class="section-title">内容分类</view>
    <view class="section-subtitle">可多选，用于后续推荐和内容整理。不选时会自动归为“未分类”。</view>
    <view class="selection-summary">已选择 {{selectedElements.length}} 项</view>

    <view class="tag-grid">
      <view
        class="tag-item {{item.selected ? 'tag-item-active' : ''}}"
        wx:for="{{elements}}"
        wx:key="label"
        bindtap="toggleElement"
        data-index="{{index}}"
      >
        <view class="tag-indicator {{item.selected ? 'tag-indicator-active' : ''}}"></view>
        <text class="tag-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="form-card comment-card" catchtap="noop">
    <view class="section-title">短评</view>
    <view class="section-subtitle">写下你的印象、推荐理由或观感。留空时会自动补成“暂无短评”。</view>
    <textarea
      class="textarea-field"
      placeholder="说点什么..."
      bindinput="inputComment"
      value="{{comment}}"
      auto-height
      show-confirm-bar="{{false}}"
      cursor-spacing="220"
      maxlength="300"
      hold-keyboard="{{true}}"
      adjust-position="{{true}}"
    />
  </view>

  <view class="action-bar">
    <button class="back-btn" bindtap="goBack">返回</button>
    <button class="save-btn" bindtap="save" loading="{{saving}}" disabled="{{saving}}">保存</button>
  </view>
</view>
