<view class="admin-content-page">
  <view class="toolbar-card">
    <view class="page-title">内容管理</view>
    <picker range="{{typeOptions}}" value="{{typeIndex}}" bindchange="onTypeChange">
      <view class="picker-box">{{typeOptions[typeIndex]}}</view>
    </picker>
    <input class="search-input" value="{{keyword}}" placeholder="搜索标题" bindinput="onKeywordInput" />
    <button class="search-btn" bindtap="search">搜索</button>
    <view class="meta-text">共 {{total}} 条，{{page}} / {{pages}} 页</view>
  </view>

  <view wx:if="{{error}}" class="error-box">{{error}}</view>
  <view wx:if="{{loading}}" class="loading-box">正在加载内容...</view>

  <view wx:if="{{!loading}}" class="list-wrap">
    <view wx:for="{{items}}" wx:key="source_item_id" class="content-card">
      <view class="content-title">{{item.title}}</view>
      <view class="content-meta">{{item.content_type === 'movie' ? '电影' : '剧集'}} / {{item.year || '未知年份'}} / {{item.rating}}</view>
      <view class="content-sub">类型：{{item.genres || '暂无'}}</view>
      <view class="content-sub">导演：{{item.director || '暂无'}}</view>
      <view class="content-sub">状态：{{item.status || '未标记'}}</view>
      <view class="content-sub">更新时间：{{item.updated_at}}</view>
    </view>
  </view>

  <view class="pager">
    <button class="pager-btn" bindtap="prevPage">上一页</button>
    <button class="pager-btn" bindtap="nextPage">下一页</button>
  </view>
</view>
