.admin-login-page {
  min-height: 100vh;
  padding: 40rpx 28rpx;
  background: linear-gradient(180deg, #efe3cf 0%, #f7f2ea 100%);
}

.hero-card,
.form-card {
  background: rgba(255, 252, 247, 0.96);
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 18rpx 48rpx rgba(69, 45, 17, 0.08);
}

.hero-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.hero-mark {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #c8643b, #e2a55b);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #241810;
}

.hero-subtitle {
  margin-top: 8rpx;
  color: #7a6758;
  font-size: 26rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: #6d5f52;
}

.input {
  width: 100%;
  background: #fff;
  border: 2rpx solid #e7d9c6;
  border-radius: 18rpx;
  padding: 22rpx 20rpx;
  font-size: 30rpx;
}

.error-text {
  color: #b2411e;
  margin-bottom: 20rpx;
  font-size: 26rpx;
}

.submit-btn {
  margin-top: 8rpx;
  border-radius: 18rpx;
  background: #c8643b;
  color: #fff;
}
