.container {
  min-height: 100vh;
  padding: 26rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 244, 226, 0.95) 0, rgba(255, 244, 226, 0) 34%),
    linear-gradient(180deg, #f7f0e7 0%, #f2eadf 46%, #efe6da 100%);
  box-sizing: border-box;
}

.search-bar,
.top-bar,
.movie-item,
.loading,
.empty {
  background: rgba(255, 252, 247, 0.94);
  border: 1rpx solid rgba(122, 92, 62, 0.08);
  border-radius: 28rpx;
  box-shadow: 0 20rpx 50rpx rgba(63, 42, 22, 0.08);
}

.search-bar,
.top-bar,
.loading,
.empty {
  padding: 24rpx;
}

.search-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.page-title {
  flex: 1;
  min-width: 0;
  font-size: 38rpx;
  font-weight: 700;
  color: #24180f;
}

.action-buttons {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10rpx;
  flex-shrink: 0;
}

.batch-btn,
.clear-btn,
.delete-btn,
.item-delete-btn {
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.compact-btn {
  min-width: 136rpx;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 20rpx;
  font-size: 22rpx;
}

.batch-btn {
  background: linear-gradient(135deg, #e7ded1 0%, #d9ccb9 100%);
  color: #4f4135;
}

.clear-btn,
.delete-btn,
.item-delete-btn {
  background: linear-gradient(135deg, #c2554b 0%, #a63e37 100%);
  color: #fff;
}

.top-bar {
  margin-bottom: 20rpx;
}

.loading,
.empty {
  text-align: center;
  color: #6f5e4e;
  font-size: 26rpx;
}

.grid-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.grid-row {
  display: flex;
  gap: 18rpx;
}

.grid-col {
  flex: 1;
  min-width: 0;
}

.movie-item {
  width: 100%;
  padding: 20rpx;
  position: relative;
  box-sizing: border-box;
}

.selector {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  z-index: 10;
}

.cover-image {
  width: 100%;
  height: 300rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #f3e7d8 0%, #ead6bf 100%);
}

.movie-info {
  margin-top: 16rpx;
}

.title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #24180f;
  line-height: 1.4;
}

.type,
.rating,
.year,
.tags,
.comment {
  display: block;
  margin-top: 8rpx;
  color: #715d4a;
  font-size: 24rpx;
  line-height: 1.6;
}

.item-delete-btn {
  width: 100%;
  margin-top: 16rpx;
}
