.container {
  padding: 10px;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 搜索栏/标题栏 */
.search-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  margin-bottom: 15px;
  border-bottom: 1px solid #eee;
}

.page-title {
  font-size: 20px;
  font-weight: bold;
  color: #333;
}

.action-buttons {
  display: flex;
  gap: 10px;
}

/* 操作按钮栏 */
.top-bar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 15px;
}

.batch-btn, .clear-btn, .delete-btn {
  font-size: 12px;
  padding: 5px 10px;
}

.delete-btn {
  background-color: #ff4757;
  color: white;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 50px 0;
  color: #999;
}

/* 空数据状态 */
.empty {
  text-align: center;
  padding: 50px 0;
  color: #999;
}

/* 网格布局 */
.movie-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  gap: 15px;
}

/* 单个项目 */
.movie-item {
  background: white;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  position: relative;
}

/* 选择框 */
.selector {
  position: absolute;
  top: 10px;
  right: 10px;
  transform: scale(1.2);
  z-index: 10;
}

/* 封面图片 */
.cover-image {
  width: 100%;
  height: 200px;
}

/* 信息区域 */
.movie-info {
  padding: 10px;
}

.title {
  font-size: 14px;
  font-weight: bold;
  margin-bottom: 5px;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.type, .rating, .year, .tags {
  font-size: 12px;
  color: #666;
  margin-bottom: 3px;
  display: block;
}

.type {
  color: #3742fa;
}

.rating {
  color: #ff9f43;
}

/* 删除按钮 */
.item-delete-btn {
  width: 100%;
  background: #ff4757;
  color: white;
  border: none;
  padding: 8px 0;
  margin-top: 10px;
  font-size: 12px;
}