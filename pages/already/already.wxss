/* 基础容器样式 */
.container {
  padding: 20rpx;
  background-color: #f9f9f9;
  min-height: 100vh;
}

.header {
  padding: 20rpx 0;
  text-align: center;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.list-container {
  margin-top: 20rpx;
  min-height: calc(100vh - 120rpx);
}

/* 空状态样式 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 列表布局 - 支持网格和列表两种模式 */
.item-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 网格布局样式（新增） */
.grid-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.grid-row {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.grid-col {
  flex: 1;
  min-width: 0;
}

/* 卡片样式优化 */
.item {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* 网格布局中的卡片样式 */
.grid-item {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 450rpx;
}

/* 海报图片样式（新增） */
.poster {
  width: 100%;
  height: 280rpx;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
  background-color: #f0f0f0;
  object-fit: cover;
}

.item-content {
  margin-bottom: 15rpx;
  flex: 1;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.info {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.type {
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 3rpx 8rpx;
  border-radius: 4rpx;
  margin-right: 15rpx;
  margin-bottom: 8rpx;
}

.score {
  font-size: 24rpx;
  color: #f7ba1e;
  display: flex;
  align-items: center;
}

.score-icon {
  margin-right: 5rpx;
}

.elements {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.elements-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 10rpx;
}

.elements-value {
  font-size: 24rpx;
  color: #333;
}

/* 标签样式优化（新增） */
.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: 10rpx 0;
}

.tag {
  font-size: 22rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 4rpx 10rpx;
  border-radius: 20rpx;
}

.comment {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 删除按钮样式优化 */
.delete-btn {
  background-color: #ff4d4f;
  color: white;
  padding: 12rpx 0;
  width: 100%;
  border-radius: 8rpx;
  font-size: 26rpx;
  border: none;
  margin-top: 15rpx;
}

.delete-btn:active {
  background-color: #ff7875;
}

/* 悬浮添加按钮（新增） */
.add-fab {
  position: fixed;
  bottom: 30rpx;
  right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #007aff;
  color: white;
  border: none;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.2);
  z-index: 999;
}

/* 评分相关样式（新增） */
.rating-container {
  margin-bottom: 8rpx;
}

.rating-label {
  font-size: 24rpx;
  color: #666;
}

.rating-value {
  font-size: 24rpx;
  color: #ff6b35;
  font-weight: bold;
}

.rating-star {
  color: #ffce3e;
  margin-left: 5rpx;
}

/* 元信息样式（新增） */
.meta-info {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 6rpx;
}

/* 响应式适配（新增） */
@media (max-width: 750rpx) {
  .grid-row {
    flex-direction: column;
    gap: 20rpx;
  }
  
  .grid-col {
    width: 100%;
  }
}