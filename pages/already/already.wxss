/* 完全与 movies.wxss 一致 */
.container {
  padding: 20rpx;
  background-color: #f9f9f9;
  min-height: 100vh;
}

.header {
  padding: 20rpx 0;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.list-container {
  margin-top: 20rpx;
}

.empty-state {
  text-align: center;
  padding-top: 100rpx;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.item-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.item {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.item-content {
  margin-bottom: 15rpx;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.info {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.type {
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 3rpx 8rpx;
  border-radius: 4rpx;
  margin-right: 15rpx;
}

.score {
  font-size: 24rpx;
  color: #f7ba1e;
}

.elements {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.elements-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 10rpx;
}

.elements-value {
  font-size: 24rpx;
  color: #333;
}

.comment {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
}

.delete-btn {
  background-color: #ff4d4f;
  color: white;
  padding: 8rpx 0;
  width: 100%;
  border-radius: 8rpx;
  font-size: 26rpx;
}