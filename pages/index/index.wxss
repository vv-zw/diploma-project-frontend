.container {
  padding: 15px;

}

.filter {
  margin-bottom: 20px;
}

/* 全部按钮样式 - 统一基础样式 */
button {
  cursor: pointer;
  transition: all 0.1s ease; /* 统一过渡效果 */
  border-radius: 4px;
  padding: 10px 0;
  border: none; /* 基础无边框，特殊按钮单独设置 */
}

/* 鼠标悬停时统一变灰色效果 */
button:hover {
  background-color: #e0e0e0 !important; /* 强制应用灰色背景 */
  color: #666 !important; /* 文字变灰 */
  border-color: #ccc !important; /* 边框同步变灰 */
}

/* 顶部按钮组 */
.btn-group-top {
  width: 100%;
  margin-bottom: 15px;
  display: flex;
  justify-content: center;
}

.btn-group-top button {
  width: 100%;
  max-width: 300px;
  font-size: 17px;
  background-color: rgb(82, 180, 236);
  border: 1px solid rgb(41, 122, 228);
  color: white; /* 文字默认白色 */
}

/* 分类按钮容器 */
.btn-group-bottom {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* 每行两个按钮 */
.btn-row {
  display: flex;
  justify-content: center;
  gap: 15px;
}

.btn-row button {
  flex: 1;
  max-width: 150px;
  font-size: 16px;
  background-color: #f5f5f5; /* 底部按钮默认浅灰 */
  color: #333; /* 底部按钮默认文字色 */
}
.btn-center button{
  width: 100%;
  max-width: 300px;
  font-size: 17px;
  border: 1px solid ; 
  box-shadow: 0 4rpx 12rpx rgba(0, 140, 255, 0.1); 
  color: rgb(41, 122, 228); /* 文字默认白色 */
  margin: 30px;
}
/* 首页欢迎文本样式 */
.welcome {
  /* 基础文本样式 */
  font-size: 40rpx;
  color: #333; /* 主色调，清晰易读 */
  text-align: center; /* 居中显示 */
  font-family: '宋体';
 /* 轻微阴影，提升层次感 */
  font-weight: 1000;
  /* 布局与间距 */
  display: block; /* 独占一行，方便设置边距 */
  padding: 40rpx 20rpx; /* 上下内边距稍大，增强呼吸感 */
  margin: 10rpx auto 20rpx; /* 顶部小间距，底部大间距分隔内容 */
  
  /* 视觉增强 */
}

/* 底部添加按钮 */
.add-btn {
  position: fixed;
  bottom: 30px;
  right: 30px;
  width: 60px;
  height: 60px;
  border-radius: 50%;
  line-height: 60px;
  padding: 0;
  background-color: rgb(82, 180, 236);
  border: 1px solid rgb(41, 122, 228);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}

/* 列表样式 */
.list {
  margin-bottom: 80px;
}

.item {
  padding: 15px;
  border: 1px solid #eee;
  border-radius: 8px;
  margin-bottom: 10px;
}

.name {
  font-size: 18px;
  font-weight: bold;
}

.score {
  color: #f7ba1e;
  margin-left: 10px;
}

.type {
  display: block;
  margin: 5px 0;
  color: #666;
}

.comment {
  display: block;
  color: #333;
  margin: 5px 0;
}

/* 删除按钮特殊样式 */
.delete {
  margin-top: 10px;
  background: #ff4d4f;
  color: white;
  padding: 5px 10px;
  border-radius: 4px;
}

/* 空状态样式 */
.empty {
  text-align: center;
  color: #999;
  margin-top: 50px;
}