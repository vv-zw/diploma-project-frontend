.page-container {
  min-height: 100vh;
  padding: 26rpx 26rpx 180rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 244, 226, 0.95) 0, rgba(255, 244, 226, 0) 34%),
    linear-gradient(180deg, #f7f0e7 0%, #f2eadf 46%, #efe6da 100%);
  box-sizing: border-box;
}

.hero-card,
.filter-card,
.item-card,
.empty-card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 252, 247, 0.94);
  border: 1rpx solid rgba(122, 92, 62, 0.08);
  border-radius: 32rpx;
  box-shadow: 0 20rpx 50rpx rgba(63, 42, 22, 0.08);
  backdrop-filter: blur(12rpx);
}

.hero-card {
  padding: 34rpx 30rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #fff8ee 0%, #f7ecdf 58%, #f0dfd1 100%);
}

.hero-glow {
  position: absolute;
  border-radius: 999rpx;
  opacity: 0.7;
}

.hero-glow-one {
  top: -50rpx;
  right: -20rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(200, 100, 59, 0.12);
}

.hero-glow-two {
  right: 110rpx;
  bottom: -70rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(36, 54, 60, 0.1);
}

.hero-tag {
  position: relative;
  z-index: 1;
  display: inline-block;
  margin-bottom: 18rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #7f6249;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  font-weight: 700;
}

.page-title {
  position: relative;
  z-index: 1;
  font-size: 48rpx;
  font-weight: 700;
  color: #24170f;
  line-height: 1.28;
}

.page-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 14rpx;
  max-width: 540rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #766657;
}

.filter-card {
  padding: 30rpx;
  margin-bottom: 28rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #24180f;
}

.section-subtitle {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #8a7a6a;
}

.section-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f1e6d8;
  color: #6f5542;
  font-size: 22rpx;
  font-weight: 600;
}

button {
  border-radius: 22rpx;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 600;
}

button::after {
  border: none;
}

.primary-btn {
  margin-top: 22rpx;
  background: linear-gradient(135deg, #d16f45 0%, #ba5b36 100%);
  color: #fff;
  box-shadow: 0 14rpx 30rpx rgba(200, 100, 59, 0.22);
}

.ghost-btn {
  background: linear-gradient(135deg, #f6ecdf 0%, #efe1cf 100%);
  color: #5b4738;
}

.action-row {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
}

.action-row button {
  flex: 1;
}

.setting-btn {
  background: linear-gradient(135deg, #e7ded1 0%, #d9ccb9 100%);
  color: #4f4135;
}

.filter-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}

.filter-tile {
  min-height: 164rpx;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  box-sizing: border-box;
}

.film {
  background: linear-gradient(135deg, #24363c 0%, #314850 100%);
}

.series {
  background: linear-gradient(135deg, #6f5640 0%, #8a6d52 100%);
}

.variety {
  background: linear-gradient(135deg, #8c4b3f 0%, #b26048 100%);
}

.watchlist {
  background: linear-gradient(135deg, #c4a373 0%, #d5b487 100%);
}

.tile-icon {
  width: 54rpx;
  height: 54rpx;
  line-height: 54rpx;
  text-align: center;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.tile-body {
  flex: 1;
}

.tile-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.tile-text {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.82);
}

.list-section {
  margin-top: 4rpx;
}

.item-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
}

.item-main {
  display: flex;
  align-items: stretch;
  gap: 22rpx;
}

.item-cover {
  width: 176rpx;
  height: 236rpx;
  flex-shrink: 0;
  margin-top: 14rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f3e7d8 0%, #ead6bf 100%);
  box-shadow: 0 14rpx 28rpx rgba(68, 45, 24, 0.12);
}

.item-content {
  flex: 1;
  min-width: 0;
}

.item-decor {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 10rpx;
  background: linear-gradient(90deg, #c8643b 0%, #e0bc89 100%);
}

.item-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.item-name {
  flex: 1;
  font-size: 34rpx;
  font-weight: 700;
  color: #24180f;
  line-height: 1.4;
}

.item-score {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #fff2c8 0%, #ffe3a0 100%);
  color: #8d5e00;
  font-size: 24rpx;
  font-weight: 700;
}

.item-meta-row {
  margin-top: 20rpx;
}

.item-type {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f4ece3;
  color: #715d4a;
  font-size: 22rpx;
}

.item-comment {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #fbf7f2;
  font-size: 25rpx;
  line-height: 1.85;
  color: #4f4339;
  word-break: break-word;
}

.item-footer {
  margin-top: 22rpx;
  display: flex;
  justify-content: flex-end;
}

.delete-btn {
  min-width: 170rpx;
  background: linear-gradient(135deg, #c2554b 0%, #a63e37 100%);
  color: #fff;
}

.empty-card {
  padding: 60rpx 36rpx;
  text-align: center;
}

.empty-mark {
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: #b59d88;
}

.empty-title {
  margin-top: 14rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #342519;
}

.empty-text {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #8a7a6d;
}

.add-btn {
  position: fixed;
  right: 26rpx;
  bottom: 36rpx;
  padding: 0 32rpx;
  height: 94rpx;
  line-height: 94rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #d16f45 0%, #ba5b36 100%);
  color: #fff;
  box-shadow: 0 18rpx 34rpx rgba(200, 100, 59, 0.3);
  font-size: 28rpx;
  font-weight: 700;
}
