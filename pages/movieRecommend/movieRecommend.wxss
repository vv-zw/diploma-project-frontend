/* pages/movieRecommend/movieRecommend.wxss */
.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.refresh-btn {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 10rpx 20rpx;
  font-size: 28rpx;
  color: #666;
}

.refresh-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
}

.loading, .error, .empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-icon, .empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.retry-btn {
  background-color: #07c160;
  color: white;
  border-radius: 8rpx;
  padding: 15rpx 40rpx;
  font-size: 30rpx;
}

.empty-tip {
  font-size: 28rpx;
  color: #999;
  margin: 15rpx 0 30rpx;
}

.go-add-btn {
  background-color: #10aeff;
  color: white;
  border-radius: 8rpx;
  padding: 15rpx 40rpx;
  font-size: 30rpx;
}

.grid-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 10rpx 0;
}

.movie-item {
  padding: 15rpx;
  background-color: white;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.movie-item:active {
  transform: scale(0.98);
}

.movie-img {
  width: 100%;
  height: 240rpx;
  object-fit: cover;
  border-radius: 8rpx;
}

.movie-info {
  padding-top: 10rpx;
}

.movie-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.movie-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 5rpx;
}

.rating, .similarity {
  font-size: 24rpx;
  color: #666;
}
/* pages/movieRecommend/movieRecommend.wxss */
/* 其他样式保持不变，新增以下内容 */

/* 电影类型标签容器 */
.movie-genres {
  display: flex;
  flex-wrap: wrap;  /* 自动换行 */}

/* 单个类型标签 */
.genre-tag {
  font-size: 22rpx;
  color: rgb(235, 157, 42);
  padding: 2rpx 12rpx;
  white-space: nowrap;  /* 不换行 */
}