<view class="container">
  <view class="header">
    <text class="title">综艺列表</text>
  </view>
  
  <view class="list-container">
    <!-- 无数据时显示 -->
    <view wx:if="{{reactionList.length === 0}}" class="empty-state">
      <image src="/images/empty.png" mode="aspectFit" class="empty-image"></image>
      <text class="empty-text">暂无综艺数据</text>
    </view>
    
    <!-- 有数据时显示列表 -->
    <view wx:else class="item-list">
      <view class="item" wx:for="{{reactionList}}" wx:key="id">
        <view class="item-content">
          <!-- 综艺名称 -->
          <view class="name">{{item.name}}</view>
          
          <!-- 类型和评分 -->
          <view class="info">
            <text class="type">{{item.type}}</text>
            <text class="score">评分：{{item.score}}星</text>
          </view>
          
          <!-- 显示多选的元素 -->
          <view class="elements">
            <text class="elements-label">类型：</text>
            <text class="elements-value">{{item.selectedElements}}</text>
          </view>
          
          <!-- 影评 -->
          <view class="comment">影评：{{item.comment}}</view>
        </view>
        
        <!-- 删除按钮 -->
        <button bindtap="deleteReaction" data-id="{{item.id}}" class="delete-btn">
          删除
        </button>
      </view>
    </view>
  </view>
</view>