.page-container {
  min-height: 100vh;
  padding: 26rpx 26rpx 50rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 244, 226, 0.95) 0, rgba(255, 244, 226, 0) 34%),
    linear-gradient(180deg, #f7f0e7 0%, #f2eadf 46%, #efe6da 100%);
  box-sizing: border-box;
}

.page-container.dark-theme {
  background:
    radial-gradient(circle at top left, rgba(143, 101, 76, 0.22) 0, rgba(143, 101, 76, 0) 30%),
    linear-gradient(180deg, #241b16 0%, #1e1713 52%, #17120f 100%);
}

.hero-card,
.panel-card,
.about-card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 252, 247, 0.94);
  border: 1rpx solid rgba(122, 92, 62, 0.08);
  border-radius: 32rpx;
  box-shadow: 0 20rpx 50rpx rgba(63, 42, 22, 0.08);
}

.dark-theme .hero-card,
.dark-theme .panel-card,
.dark-theme .about-card {
  background: rgba(38, 29, 24, 0.94);
  border-color: rgba(255, 255, 255, 0.06);
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.25);
}

.hero-card {
  padding: 32rpx 30rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #fff8ee 0%, #f7ecdf 58%, #f0dfd1 100%);
}

.dark-theme .hero-card {
  background: linear-gradient(135deg, #33261f 0%, #2a201b 58%, #211915 100%);
}

.hero-top {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hero-glow {
  position: absolute;
  border-radius: 999rpx;
  opacity: 0.7;
}

.hero-glow-one {
  top: -50rpx;
  right: -20rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(200, 100, 59, 0.12);
}

.hero-glow-two {
  right: 110rpx;
  bottom: -70rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(36, 54, 60, 0.1);
}

.back-chip,
.hero-tag {
  position: relative;
  z-index: 1;
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.68);
  color: #6c5442;
  font-size: 22rpx;
  font-weight: 600;
}

.dark-theme .back-chip,
.dark-theme .hero-tag {
  background: rgba(255, 255, 255, 0.08);
  color: #ead8c6;
}

.hero-tag {
  letter-spacing: 3rpx;
  font-size: 20rpx;
}

.page-title {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  font-size: 48rpx;
  font-weight: 700;
  color: #24170f;
}

.dark-theme .page-title {
  color: #fff3e7;
}

.page-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #766657;
}

.dark-theme .page-subtitle {
  color: #cdbba9;
}

.panel-card,
.about-card {
  padding: 28rpx;
  margin-bottom: 22rpx;
}

.section-title {
  font-size: 31rpx;
  font-weight: 700;
  color: #24180f;
}

.dark-theme .section-title {
  color: #fff3e7;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  padding: 26rpx 0;
  border-bottom: 1rpx solid rgba(122, 92, 62, 0.09);
}

.setting-item:last-child {
  border-bottom: none;
  padding-bottom: 6rpx;
}

.dark-theme .setting-item {
  border-bottom-color: rgba(255, 255, 255, 0.08);
}

.item-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #2f221a;
}

.dark-theme .item-label {
  color: #fff0e2;
}

.item-desc {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #8a7a6a;
}

.dark-theme .item-desc {
  color: #b9a693;
}

.item-switch {
  transform: scale(0.9);
  transform-origin: center right;
}

.item-picker,
.item-value,
.picker-value {
  font-size: 25rpx;
  color: #6a5443;
}

.dark-theme .item-value,
.dark-theme .picker-value {
  color: #efdac8;
}

.touchable:active {
  opacity: 0.85;
}

.about-version {
  margin-top: 18rpx;
  font-size: 26rpx;
  color: #6e5b4d;
}

.about-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #907f71;
}

.dark-theme .about-version,
.dark-theme .about-desc {
  color: #c9b6a2;
}
