<view class="container">
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="请输入剧集名称"
      value="{{searchName}}"
      bindinput="onSearchInput"
    />
    <button class="search-btn" bindtap="searchShow" wx:if="{{!loading}}">搜索</button>
    <button class="search-btn" disabled wx:else>加载中...</button>
  </view>

  <view class="top-bar">
    <button class="batch-btn" bindtap="batchSearchShows">批量查询</button>
    <button class="delete-btn" bindtap="batchDelete" wx:if="{{selectedElements.length > 0}}">
      批量删除（{{selectedElements.length}}）
    </button>
    <button class="clear-btn" bindtap="clearHistory">清空历史</button>
  </view>

  <view class="error-msg" wx:if="{{errorMsg}}">
    {{errorMsg}}
  </view>

  <view class="loading" wx:if="{{loading || detailLoading}}">
    <text>加载中...</text>
  </view>

  <view class="empty" wx:elif="{{showList.length === 0 && !loading && !detailLoading}}">
    <text>暂无剧集数据，搜索添加吧</text>
  </view>

  <view class="grid-list" wx:else>
    <view class="grid-row" wx:for="{{rowCount}}" wx:for-index="rowIndex" wx:key="rowIndex">
      <view class="grid-col">
        <view class="drama-item" wx:if="{{rowIndex * 2 < showList.length}}">
          <checkbox
            class="selector"
            value="{{showList[rowIndex * 2].id || showList[rowIndex * 2].name}}"
            checked="{{selectedElements.indexOf(showList[rowIndex * 2].id || showList[rowIndex * 2].name) > -1}}"
            bindtap="handleCheckboxTap"
            data-value="{{showList[rowIndex * 2].id || showList[rowIndex * 2].name}}"
          />
          <image
            class="cover-image"
            src="{{showList[rowIndex * 2].coverUrl || showList[rowIndex * 2].cover_url || '/images/default-show.png'}}"
            mode="aspectFill"
            lazy-load
          ></image>
          <view class="drama-info">
            <text class="title">{{showList[rowIndex * 2].name || showList[rowIndex * 2].title}}</text>
            <text class="rating">评分：{{showList[rowIndex * 2].rating || '暂无'}}</text>
            <text class="genres">类型：{{showList[rowIndex * 2].genres || '未知'}}</text>
            <text class="year">年份：{{showList[rowIndex * 2].year || '未知'}}</text>
            <text class="episodes" wx:if="{{showList[rowIndex * 2].episodes}}">集数：{{showList[rowIndex * 2].episodes}}</text>
            <text class="region" wx:if="{{showList[rowIndex * 2].region}}">地区：{{showList[rowIndex * 2].region}}</text>
          </view>
          <button
            class="item-delete-btn"
            bindtap="deleteShow"
            data-id="{{showList[rowIndex * 2].id}}"
            data-name="{{showList[rowIndex * 2].name || showList[rowIndex * 2].title}}"
          >
            删除
          </button>
        </view>
      </view>

      <view class="grid-col">
        <view class="drama-item" wx:if="{{rowIndex * 2 + 1 < showList.length}}">
          <checkbox
            class="selector"
            value="{{showList[rowIndex * 2 + 1].id || showList[rowIndex * 2 + 1].name}}"
            checked="{{selectedElements.indexOf(showList[rowIndex * 2 + 1].id || showList[rowIndex * 2 + 1].name) > -1}}"
            bindtap="handleCheckboxTap"
            data-value="{{showList[rowIndex * 2 + 1].id || showList[rowIndex * 2 + 1].name}}"
          />
          <image
            class="cover-image"
            src="{{showList[rowIndex * 2 + 1].coverUrl || showList[rowIndex * 2 + 1].cover_url || '/images/default-show.png'}}"
            mode="aspectFill"
            lazy-load
          ></image>
          <view class="drama-info">
            <text class="title">{{showList[rowIndex * 2 + 1].name || showList[rowIndex * 2 + 1].title}}</text>
            <text class="rating">评分：{{showList[rowIndex * 2 + 1].rating || '暂无'}}</text>
            <text class="genres">类型：{{showList[rowIndex * 2 + 1].genres || '未知'}}</text>
            <text class="year">年份：{{showList[rowIndex * 2 + 1].year || '未知'}}</text>
            <text class="episodes" wx:if="{{showList[rowIndex * 2 + 1].episodes}}">集数：{{showList[rowIndex * 2 + 1].episodes}}</text>
            <text class="region" wx:if="{{showList[rowIndex * 2 + 1].region}}">地区：{{showList[rowIndex * 2 + 1].region}}</text>
          </view>
          <button
            class="item-delete-btn"
            bindtap="deleteShow"
            data-id="{{showList[rowIndex * 2 + 1].id}}"
            data-name="{{showList[rowIndex * 2 + 1].name || showList[rowIndex * 2 + 1].title}}"
          >
            删除
          </button>
        </view>
      </view>
    </view>
  </view>

  <view class="history-section" wx:if="{{searchHistory.length > 0}}">
    <view class="history-title">搜索历史</view>
    <view class="history-list">
      <text
        class="history-item"
        wx:for="{{searchHistory}}"
        wx:key="index"
        data-name="{{item}}"
        bindtap="selectFromHistory"
      >
        {{item}}
      </text>
    </view>
  </view>
</view>
