<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input 
      class="search-input" 
      placeholder="请输入剧集名称" 
      value="{{searchName}}"
      bindinput="onSearchInput"
    />
    <button class="search-btn" bindtap="searchShow" wx:if="{{!loading}}">搜索</button>
    <button class="search-btn" disabled wx:else>加载中...</button>
  </view>
  
  <!-- 操作按钮栏 -->
  <view class="top-bar">
    <button class="batch-btn" bindtap="batchSearchShows">批量查询</button>
    <button class="delete-btn" bindtap="batchDelete" wx:if="{{selectedElements.length > 0}}">
      批量删除({{selectedElements.length}})
    </button>
    <button class="clear-btn" bindtap="clearHistory">清空历史</button>
  </view>
  
  <!-- 错误提示 -->
  <view class="error-msg" wx:if="{{errorMsg}}">
    {{errorMsg}}
  </view>
  
  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading || detailLoading}}">
    <text>加载中...</text>
  </view>
  
  <!-- 剧集列表为空 -->
  <view class="empty" wx:elif="{{showList.length === 0 && !loading && !detailLoading}}">
    <text>暂无剧集数据，搜索添加吧</text>
  </view>
  
  <!-- 剧集网格列表 - 修改类名以匹配WXSS -->
  <view class="drama-grid" wx:else>
    <view class="drama-item" wx:for="{{showList}}" wx:key="id">
      <!-- 选择框 -->
      <checkbox class="selector" value="{{item.id || item.name}}" bindchange="checkboxChange"/>
      
      <!-- 封面图 -->
      <image 
        class="cover-image" 
        src="{{item.coverUrl || item.cover_url || '/images/default-show.png'}}" 
        mode="aspectFill"
        lazy-load
      ></image>
      
      <!-- 剧集信息 - 修改类名以匹配WXSS -->
      <view class="drama-info">
        <text class="title">{{item.name || item.title}}</text>
        <text class="rating">评分: {{item.rating || '暂无'}}</text>
        <text class="genres">类型: {{item.genres || '未知'}}</text>
        <text class="year">年份: {{item.year}}</text>
        <text class="episodes" wx:if="{{item.episodes}}">集数: {{item.episodes}}</text>
        <text class="region" wx:if="{{item.region}}">地区: {{item.region}}</text>
      </view>
      
      <!-- 删除按钮 -->
      <button 
        class="item-delete-btn" 
        bindtap="deleteShow" 
        data-id="{{item.id}}" 
        data-name="{{item.name || item.title}}"
      >
        删除
      </button>
    </view>
  </view>
  
  <!-- 历史记录 -->
  <view class="history-section" wx:if="{{searchHistory.length > 0}}">
    <view class="history-title">搜索历史</view>
    <view class="history-list">
      <text 
        class="history-item" 
        wx:for="{{searchHistory}}" 
        wx:key="index"
        data-name="{{item}}"
        bindtap="selectFromHistory"
      >
        {{item}}
      </text>
    </view>
  </view>
</view>