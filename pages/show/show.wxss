.container {
  padding: 10rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 搜索栏样式 */
.search-bar {
  display: flex;
  margin-bottom: 20rpx;
  gap: 10rpx;
}

.search-input {
  flex: 1;
  padding: 15rpx;
  background-color: white;
  border-radius: 30rpx;
  font-size: 28rpx;
  border: 1rpx solid #eee;
}

.search-btn {
  padding: 0 30rpx;
  background-color: #1989fa;
  color: white;
  border-radius: 30rpx;
  font-size: 28rpx;
}

/* 顶部操作栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  margin-bottom: 20rpx;
}

.batch-btn, .delete-btn, .clear-btn {
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
}

.batch-btn {
  background-color: #07c160;
  color: white;
}

.delete-btn {
  background-color: #f53f3f;
  color: white;
}

.clear-btn {
  background-color: #999;
  color: white;
}

/* 错误提示 */
.error-msg {
  color: #f53f3f;
  font-size: 28rpx;
  text-align: center;
  padding: 20rpx;
}

.loading, .empty {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 32rpx;
  color: #999;
}

/* 剧集网格布局 - 强制一行两列 */
.drama-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0;
  padding: 0;
}

.drama-item {
  width: 48%;
  margin: 1%;
  background-color: white;
  border-radius: 12rpx;
  padding: 15rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: relative;
  box-sizing: border-box;
}

.selector {
  position: absolute;
  top: 15rpx;
  right: 15rpx;
  z-index: 10;
  transform: scale(1.2);
}

.cover-image {
  width: 100%;
  height: 300rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

.drama-info {
  margin-top: 15rpx;
}

.title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.rating {
  display: block;
  font-size: 26rpx;
  color: #ff9500;
  margin-bottom: 4rpx;
}

.genres, .year, .episodes, .region {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.item-delete-btn {
  width: 100%;
  margin-top: 15rpx;
  background-color: #fef0f0;
  color: #f53f3f;
  font-size: 26rpx;
}

/* 历史记录样式 */
.history-section {
  margin-top: 30rpx;
}

.history-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  color: #333;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.history-item {
  padding: 10rpx 20rpx;
  background-color: white;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
  box-shadow: 0 1rpx 5rpx rgba(0, 0, 0, 0.1);
}