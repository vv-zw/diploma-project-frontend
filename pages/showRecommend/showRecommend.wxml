<!-- pages/showRecommend/showRecommend.wxml -->
<view class="container">
  <!-- 顶部标签栏 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'recommend' ? 'active' : ''}}" data-tab="recommend" bindtap="switchTab">
      推荐
    </view>
    <view class="tab-item {{activeTab === 'search' ? 'active' : ''}}" data-tab="search" bindtap="switchTab">
      搜索
    </view>
    <view class="tab-item {{activeTab === 'watchlist' ? 'active' : ''}}" data-tab="watchlist" bindtap="switchTab">
      想看清单
    </view>
  </view>

  <!-- 推荐标签内容 -->
  <block wx:if="{{activeTab === 'recommend'}}">
    <view class="header">
      <text class="title">剧集推荐</text>
      <button class="refresh-btn" bindtap="refreshRecommendations">
        刷新
      </button>
    </view>

    <view class="sync-status" wx:if="{{syncStatus}}">{{syncStatus}}</view>

    <!-- 推荐依据 -->
    <view class="tags-container" wx:if="{{Object.keys(countWeights).length > 0}}">
      <text class="tags-title">为你推荐：</text>
      <block wx:for="{{Object.keys(countWeights)}}" wx:key="index">
        <view class="tag">{{item}} ×{{countWeights[item]}}</view>
      </block>
    </view>

    <!-- 加载状态 -->
    <view class="loading" wx:if="{{loading}}">
      <text>加载推荐中...</text>
    </view>

    <!-- 错误状态 -->
    <view class="error" wx:if="{{!loading && error}}">
      <text class="error-text">{{error}}</text>
      <button class="retry-btn" bindtap="refreshRecommendations">重试</button>
    </view>

    <!-- 空数据状态 -->
    <view class="empty" wx:if="{{!loading && !error && gridList.length === 0}}">
      <image class="empty-img" src="/images/empty.png"></image>
      <text>暂无推荐剧集</text>
      <text class="empty-tip">添加喜欢的剧集，获取个性化推荐</text>
      <button class="go-add-btn" bindtap="goToAddSeries">去添加</button>
    </view>

    <!-- 网格布局 - 修改为一行三列 -->
    <view class="series-grid" wx:if="{{!loading && !error && gridList.length > 0}}">
      <block wx:for="{{gridList}}" wx:for-index="rowIdx" wx:for-item="row" wx:key="rowIdx">
        <block wx:for="{{row}}" wx:for-index="colIdx" wx:for-item="series" wx:key="series.id">
          <view class="series-card" bindtap="goToDetail" data-id="{{series.id}}">
            <image 
              class="series-poster" 
              src="{{series.cover_url}}" 
              mode="aspectFill"
              lazy-load="true"
              binderror="onImageError"
              data-id="{{series.id}}"
            ></image>
            
            <view class="series-actions">
              <button class="action-btn watch-btn" catchtap="addToWatchlist" data-id="{{series.id}}">
                <text>想看</text>
              </button>
              <button class="action-btn dislike-btn" catchtap="handleNegativeFeedback" data-id="{{series.id}}">
                <text>不感兴趣</text>
              </button>
            </view>
            
            <view class="series-info">
              <text class="series-title">{{series.title}}</text>
              <text class="series-year" wx:if="{{series.year}}">{{series.year}}</text>
              <view class="series-genres">
                <text wx:for="{{series.genres.slice(0,2)}}" wx:for-item="genre" wx:key="genre" class="genre-tag">
                  {{genre}}
                </text>
              </view>
              <view class="series-meta">
                <text class="rating">评分：{{series.rating}}</text>
                <text class="similarity" wx:if="{{series.similarity}}">{{series.similarity}}%</text>
              </view>
            </view>
          </view>
        </block>
      </block>
    </view>
  </block>

  <!-- 搜索标签内容 -->
  <block wx:if="{{activeTab === 'search'}}">
    <view class="search-page">
      <view class="search-box">
        <input 
          class="search-input" 
          placeholder="搜索剧集、类型、导演..." 
          value="{{searchQuery}}" 
          bindinput="onSearchInput"
          confirm-type="search"
          bindconfirm="searchSeries"
        />
        <button class="search-btn" bindtap="searchSeries">
          <text>搜索</text>
        </button>
        <button class="clear-btn" wx:if="{{searchQuery}}" bindtap="clearSearch">
          <text>×</text>
        </button>
      </view>

      <view class="search-results" wx:if="{{showSearch}}">
        <view class="result-count" wx:if="{{searchResults.length > 0}}">
          找到 {{searchResults.length}} 个结果
        </view>
        
        <view class="loading" wx:if="{{loading}}">
          <text>搜索中...</text>
        </view>
        
        <view class="results-list" wx:elif="{{searchResults.length > 0}}">
          <view class="search-item" 
            wx:for="{{searchResults}}" 
            wx:key="item.id"
            bindtap="goToDetail"
            data-id="{{item.id}}"
          >
            <image 
              class="search-item-img" 
              src="{{item.cover_url}}" 
              mode="aspectFill"
              binderror="onImageError"
              data-id="{{item.id}}"
            ></image>
            
            <view class="search-item-info">
              <view class="search-item-header">
                <text class="search-item-title">{{item.title}}</text>
                <text class="search-item-year" wx:if="{{item.year}}">{{item.year}}</text>
              </view>
              
              <text class="search-item-director" wx:if="{{item.director}}">导演：{{item.director}}</text>
              
              <view class="search-item-genres">
                <text wx:for="{{item.genres.slice(0,3)}}" wx:for-item="genre" wx:key="genre" class="genre-tag">
                  {{genre}}
                </text>
              </view>
              
              <view class="search-item-meta">
                <text class="rating">评分：{{item.rating}}</text>
              </view>
            </view>
            
            <button class="add-watch-btn" catchtap="addToWatchlist" data-id="{{item.id}}">
              想看
            </button>
          </view>
        </view>
        
        <view class="empty" wx:elif="{{searchQuery}}">
          <image class="empty-img" src="/images/empty.png"></image>
          <text>没有找到 "{{searchQuery}}" 相关结果</text>
          <text class="empty-tip">尝试其他关键词</text>
        </view>
      </view>
    </view>
  </block>

  <!-- 想看清单标签内容 -->
  <block wx:if="{{activeTab === 'watchlist'}}">
    <view class="watchlist-page">
      <view class="watchlist-header">
        <text class="title">我的想看清单</text>
        <text class="count" wx:if="{{alreadyList.length > 0}}">{{alreadyList.length}} 部剧集</text>
      </view>
      
      <view class="empty" wx:if="{{alreadyList.length === 0}}">
        <image class="empty-img" src="/images/empty.png"></image>
        <text>你的想看清单还是空的</text>
        <text class="empty-tip">添加感兴趣的剧集到清单中</text>
        <button class="go-recommend-btn" bindtap="switchTab" data-tab="recommend">去看看推荐</button>
      </view>
      
      <view class="watchlist-list" wx:else>
        <view class="watchlist-item" 
          wx:for="{{alreadyList}}" 
          wx:key="item.id"
          bindtap="goToDetail"
          data-id="{{item.id}}"
        >
          <image 
            class="watchlist-item-img" 
            src="{{item.cover_url}}" 
            mode="aspectFill"
          ></image>
          
          <view class="watchlist-item-info">
            <text class="watchlist-item-title">{{item.title}}</text>
            <text class="watchlist-item-year" wx:if="{{item.year}}">{{item.year}}</text>
            
            <view class="watchlist-item-genres">
              <text wx:for="{{item.selectedElements.slice(0,2)}}" wx:for-item="genre" wx:key="genre" class="genre-tag">
                {{genre}}
              </text>
            </view>
            
            <text class="rating">评分：{{item.rating}}</text>
          </view>
          
          <button class="delete-btn" catchtap="deleteAlready" data-id="{{item.id}}">
            删除
          </button>
        </view>
      </view>
    </view>
  </block>

  <!-- 添加剧集按钮 -->
  <button class="add-fab" bindtap="goToAddSeries">+</button>
</view>