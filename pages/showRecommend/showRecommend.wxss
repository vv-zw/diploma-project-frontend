/* pages/showRecommend/showRecommend.wxss */
.container {
  padding: 10rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 标签栏样式 */
.tab-bar {
  display: flex;
  background-color: white;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 25rpx 0;
  font-size: 32rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #007aff;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background-color: #007aff;
  border-radius: 3rpx;
}

/* 头部样式 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.refresh-btn {
  background-color: #007aff;
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 28rpx;
}

/* 标签容器 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: 20rpx 0;
  align-items: center;
}

.tags-title {
  font-size: 28rpx;
  color: #666;
}

.tag {
  background-color: #e8f4f8;
  color: #007aff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
}

/* 加载和错误样式 */
.loading, .error, .empty {
  text-align: center;
  padding: 100rpx 0;
}

.error-text {
  color: #ff3b30;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.empty-img {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.5;
  margin-bottom: 30rpx;
}

/* 剧集网格布局 - 修改为一行三列 */
.series-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 15rpx;
}

.series-card {
  width: calc(33.333% - 10rpx);
  background-color: white;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  display: flex;
  flex-direction: column;
}

.series-poster {
  width: 100%;
  height: 220rpx;
  object-fit: cover;
}

/* 操作按钮组 */
.series-actions {
  display: flex;
  margin: 10rpx;
}

.action-btn {
  flex: 1;
  margin: 0 5rpx;
  padding: 8rpx 0;
  font-size: 22rpx;
  border-radius: 5rpx;
}

.watch-btn {
  background-color: #007aff;
  color: white;
}

.dislike-btn {
  background-color: #f2f2f7;
  color: #666;
}

.series-info {
  padding: 10rpx 15rpx;
  flex: 1;
}

.series-title {
  font-size: 26rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 5rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.series-year {
  font-size: 22rpx;
  color: #999;
}

.series-genres {
  margin: 8rpx 0;
}

.genre-tag {
  background-color: #f0f0f0;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  margin-right: 6rpx;
}

.series-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #666;
}

.rating {
  color: #ff9500;
}

/* 搜索页面样式 */
.search-page {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
}

.search-box {
  display: flex;
  align-items: center;
  border: 1rpx solid #eee;
  border-radius: 30rpx;
  padding: 0 20rpx;
}

.search-input {
  flex: 1;
  height: 70rpx;
  font-size: 28rpx;
}

.search-btn, .clear-btn {
  padding: 0 20rpx;
  font-size: 28rpx;
}

.search-results {
  margin-top: 30rpx;
}

.results-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.search-item {
  display: flex;
  padding: 15rpx;
  border-bottom: 1rpx solid #eee;
}

.search-item-img {
  width: 120rpx;
  height: 160rpx;
  border-radius: 8rpx;
}

.search-item-info {
  flex: 1;
  margin-left: 20rpx;
}

.search-item-title {
  font-size: 30rpx;
  font-weight: bold;
}

.add-watch-btn {
  background-color: #007aff;
  color: white;
  border: none;
  border-radius: 15rpx;
  padding: 10rpx 20rpx;
  height: 60rpx;
  margin: auto 0;
}

/* 想看清单样式 */
.watchlist-page {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
}

.watchlist-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.count {
  font-size: 26rpx;
  color: #666;
}

.watchlist-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.watchlist-item {
  display: flex;
  padding: 15rpx;
  border-bottom: 1rpx solid #eee;
}

.watchlist-item-img {
  width: 100rpx;
  height: 140rpx;
  border-radius: 8rpx;
}

.watchlist-item-info {
  flex: 1;
  margin-left: 20rpx;
}

.delete-btn {
  background-color: #ff3b30;
  color: white;
  border: none;
  border-radius: 15rpx;
  padding: 10rpx 20rpx;
  height: 60rpx;
  margin: auto 20rpx;
}

/* 悬浮按钮 */
.add-fab {
  position: fixed;
  bottom: 30rpx;
  right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #007aff;
  color: white;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

.sync-status {
  background-color: #e8f4f8;
  color: #007aff;
  text-align: center;
  padding: 10rpx;
  border-radius: 5rpx;
  margin-bottom: 20rpx;
}